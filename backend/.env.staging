NODE_ENV=staging
PORT=5000

DB_HOST=staging-db-host
DB_PORT=5432
DB_USER=postgres
DB_NAME=loginapp_staging
DB_PASSWORD=staging_password
DATABASE_URL=postgresql://postgres:staging_password@staging-db-host:5432/loginapp_staging

JWT_SECRET=staging_secret_key
JWT_EXPIRES_IN=1d

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=staging@example.com
SMTP_PASS=staging_smtp_password
EMAIL_FROM=noreply@loginapp.staging

CACHE_TTL=300
DEFAULT_PAGE_LIMIT=20
MAX_FILE_SIZE=5242880
LOG_LEVEL=info
