# Backend Environment Variables
# Copy this to .env and update the values

NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=loginapp
DB_PASSWORD=your_password_here
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/loginapp

# JWT
JWT_SECRET=your_secret_key_change_in_production
JWT_EXPIRES_IN=1d

# Email (SMTP)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@loginapp.dev

# App Settings
CACHE_TTL=300
DEFAULT_PAGE_LIMIT=20
MAX_FILE_SIZE=5242880
LOG_LEVEL=debug
FRONTEND_URL=http://localhost:3000
